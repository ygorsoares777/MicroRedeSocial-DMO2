<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F58220">

    <!-- Toolbar com botão de voltar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#F58220"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:navigationContentDescription="Voltar">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Editar Perfil"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_gravity="center" />

    </androidx.appcompat.widget.Toolbar>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="32dp"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <!-- Foto de Perfil -->
            <androidx.cardview.widget.CardView
                android:layout_width="100dp"
                android:layout_height="100dp"
                app:cardCornerRadius="50dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="16dp">

                <ImageView
                    android:id="@+id/imgFotoPerfil"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/empty_profile"
                    android:scaleType="centerCrop" />
            </androidx.cardview.widget.CardView>

            <!-- Botão Alterar Foto -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAlterarFoto"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="ALTERAR FOTO"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#F58220"
                app:backgroundTint="#FFFFFF"
                app:cornerRadius="28dp"
                android:layout_marginBottom="24dp" />

            <!-- Username -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nome de usuário"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginStart="8dp"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/edtUsername"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Digite seu nome de usuário"
                android:background="#FFFFFF"
                android:padding="16dp"
                android:textColor="#1A1C1E"
                android:textColorHint="#888888"
                android:layout_marginBottom="16dp" />

            <!-- Nome completo -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nome completo"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginStart="8dp"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/edtNomeCompleto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Digite seu nome completo"
                android:background="#FFFFFF"
                android:padding="16dp"
                android:textColor="#1A1C1E"
                android:textColorHint="#888888"
                android:layout_marginBottom="16dp" />

            <!-- Senha atual com ícone de olho -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Senha atual *"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginStart="8dp"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                app:boxStrokeColor="#FFFFFF"
                app:hintTextColor="#FFFFFF"
                app:boxBackgroundColor="#FFFFFF"
                app:passwordToggleEnabled="true"
                app:passwordToggleTint="#F58220"
                android:layout_marginBottom="16dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edtSenhaAtual"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Digite sua senha atual"
                    android:inputType="textPassword"
                    android:textColor="#1A1C1E"
                    android:textColorHint="#888888" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Nova senha com ícone de olho -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nova senha"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginStart="8dp"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                app:boxStrokeColor="#FFFFFF"
                app:hintTextColor="#FFFFFF"
                app:boxBackgroundColor="#FFFFFF"
                app:passwordToggleEnabled="true"
                app:passwordToggleTint="#F58220"
                android:layout_marginBottom="16dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edtNovaSenha"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Digite a nova senha"
                    android:inputType="textPassword"
                    android:textColor="#1A1C1E"
                    android:textColorHint="#888888" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Confirmar senha com ícone de olho -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Confirmar nova senha"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginStart="8dp"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                app:boxStrokeColor="#FFFFFF"
                app:hintTextColor="#FFFFFF"
                app:boxBackgroundColor="#FFFFFF"
                app:passwordToggleEnabled="true"
                app:passwordToggleTint="#F58220"
                android:layout_marginBottom="24dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edtConfirmarSenha"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Confirme a nova senha"
                    android:inputType="textPassword"
                    android:textColor="#1A1C1E"
                    android:textColorHint="#888888" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Botão Salvar -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSalvar"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="SALVAR"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#F58220"
                app:backgroundTint="#FFFFFF"
                app:cornerRadius="28dp"
                android:layout_marginBottom="16dp" />

            <!-- Botão Sair -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSair"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="SAIR"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                app:backgroundTint="@android:color/transparent"
                app:cornerRadius="28dp"
                app:strokeColor="#FFFFFF"
                app:strokeWidth="1.5dp"
                android:layout_marginBottom="24dp" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>